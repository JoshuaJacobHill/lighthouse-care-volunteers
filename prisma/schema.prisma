// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication ───────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Roles ────────────────────────────────────────────────────────────

enum UserRole {
  VOLUNTEER
  ADMIN
  SUPER_ADMIN
  KIOSK
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  role          UserRole  @default(VOLUNTEER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  accounts         Account[]
  sessions         UserSession[]
  volunteerProfile VolunteerProfile?
  adminNotes       AdminNote[]       @relation("NoteCreatedBy")
  emailLogs        EmailLog[]        @relation("EmailSentBy")
}

// ─── Volunteer Profiles ───────────────────────────────────────────────────────

enum VolunteerStatus {
  PENDING_INDUCTION
  INDUCTED
  ACTIVE
  INACTIVE
  PAUSED
  REMOVED
}

enum BlueCardStatus {
  NOT_APPLICABLE
  PENDING
  CURRENT
  EXPIRED
}

model VolunteerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Personal details
  firstName    String
  lastName     String
  email        String
  mobile       String
  dateOfBirth  DateTime?
  addressLine1 String?
  addressLine2 String?
  suburb       String?
  state        String?
  postcode     String?

  // Emergency contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Status
  status            VolunteerStatus @default(PENDING_INDUCTION)
  joinedAt          DateTime        @default(now())
  lastActiveAt      DateTime?
  lastAttendedAt    DateTime?
  deactivatedAt     DateTime?
  deactivatedReason String?

  // Preferences
  preferredLocations String[]
  areasOfInterest    String[]
  notes              String?  @db.Text
  medicalNotes       String?  @db.Text
  accessibilityNeeds String?  @db.Text

  // Blue Card
  blueCardStatus BlueCardStatus @default(NOT_APPLICABLE)
  blueCardNumber String?
  blueCardExpiry DateTime?

  // Consents
  agreedToTerms       Boolean   @default(false)
  agreedToPrivacy     Boolean   @default(false)
  consentEmailUpdates Boolean   @default(false)
  consentSmsUpdates   Boolean   @default(false)
  agreedAt            DateTime?

  avatarUrl String?

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability      VolunteerAvailability[]
  inductionProgress InductionProgress[]
  shiftAssignments  ShiftAssignment[]
  attendanceRecords AttendanceRecord[]
  adminNotes        AdminNote[]
  emailLogs         EmailLog[]
  quizAnswers       InductionQuizAnswer[]

  @@index([status])
  @@index([lastAttendedAt])
  @@index([email])
}

// ─── Availability ─────────────────────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TimePeriod {
  MORNING
  AFTERNOON
  EVENING
}

model VolunteerAvailability {
  id          String     @id @default(cuid())
  volunteerId String
  dayOfWeek   DayOfWeek
  timePeriod  TimePeriod
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, dayOfWeek, timePeriod])
}

// ─── Locations & Departments ──────────────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts          Shift[]
  attendance      AttendanceRecord[]
  guestAttendance GuestAttendanceRecord[]
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]
}

// ─── Induction ────────────────────────────────────────────────────────────────

model InductionSection {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  sortOrder  Int      @default(0)
  isRequired Boolean  @default(true)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  progress InductionProgress[]
}

model InductionProgress {
  id          String    @id @default(cuid())
  volunteerId String
  sectionId   String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  section   InductionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, sectionId])
}

model InductionQuizQuestion {
  id        String   @id @default(cuid())
  question  String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options InductionQuizOption[]
  answers InductionQuizAnswer[]
}

model InductionQuizOption {
  id         String  @id @default(cuid())
  questionId String
  optionText String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question InductionQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  InductionQuizAnswer[]
}

model InductionQuizAnswer {
  id          String   @id @default(cuid())
  volunteerId String
  questionId  String
  optionId    String
  isCorrect   Boolean
  answeredAt  DateTime @default(now())

  volunteer VolunteerProfile      @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  question  InductionQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option    InductionQuizOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, questionId])
}

// ─── Shifts & Rostering ───────────────────────────────────────────────────────

enum ShiftAssignmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED_BY_VOLUNTEER
  ATTENDED
  NO_SHOW
  ADMIN_CANCELLED
}

model Shift {
  id           String    @id @default(cuid())
  locationId   String
  departmentId String?
  title        String?
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  capacity     Int       @default(1)
  isRecurring  Boolean   @default(false)
  recurringId  String?
  notes        String?   @db.Text
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?

  location    Location    @relation(fields: [locationId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  assignments ShiftAssignment[]

  @@index([date])
  @@index([locationId])
}

model ShiftAssignment {
  id           String                @id @default(cuid())
  shiftId      String
  volunteerId  String
  status       ShiftAssignmentStatus @default(SCHEDULED)
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  createdById  String?

  shift     Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, volunteerId])
  @@index([status])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model AttendanceRecord {
  id           String    @id @default(cuid())
  volunteerId  String
  locationId   String?
  shiftId      String?
  signInAt     DateTime  @default(now())
  signOutAt    DateTime?
  durationMins Int?
  kioskName    String?
  ipAddress    String?
  notes        String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  location  Location?        @relation(fields: [locationId], references: [id])

  @@index([volunteerId])
  @@index([signInAt])
  @@index([locationId])
}

model GuestAttendanceRecord {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  mobile             String?
  email              String?
  volunteerArea      String?
  emergencyContact   String?
  safetyAcknowledged Boolean   @default(false)
  locationId         String?
  signInAt           DateTime  @default(now())
  signOutAt          DateTime?
  durationMins       Int?
  kioskName          String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])

  @@index([signInAt])
}

// ─── Admin Notes ──────────────────────────────────────────────────────────────

model AdminNote {
  id          String   @id @default(cuid())
  volunteerId String
  content     String   @db.Text
  isInternal  Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  createdBy User             @relation("NoteCreatedBy", fields: [createdById], references: [id])
}

// ─── Email System ─────────────────────────────────────────────────────────────

enum EmailTemplateType {
  SIGNUP_CONFIRMATION
  INDUCTION_REMINDER
  INDUCTION_COMPLETE
  SHIFT_REMINDER
  SHIFT_CANCELLED
  MISSED_SHIFT_FOLLOWUP
  INACTIVITY_CHECKIN
  ADMIN_NEW_VOLUNTEER
  ADMIN_REPEATED_NOSHOWS
  CUSTOM
}

model EmailTemplate {
  id       String            @id @default(cuid())
  type     EmailTemplateType @unique
  name     String
  subject  String
  bodyHtml String            @db.Text
  bodyText String?           @db.Text
  isActive Boolean           @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

model EmailLog {
  id           String             @id @default(cuid())
  to           String
  subject      String
  templateType EmailTemplateType?
  status       EmailStatus        @default(PENDING)
  sentAt       DateTime?
  errorMsg     String?
  volunteerId  String?
  sentById     String?
  metadata     Json?
  createdAt    DateTime           @default(now())

  volunteer VolunteerProfile? @relation(fields: [volunteerId], references: [id])
  sentBy    User?             @relation("EmailSentBy", fields: [sentById], references: [id])

  @@index([volunteerId])
  @@index([sentAt])
}

// ─── App Settings ─────────────────────────────────────────────────────────────

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  group     String?
  updatedAt DateTime @updatedAt

  @@index([group])
}
